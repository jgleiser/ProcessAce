# .editorconfig
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
max_line_length = 150

[package.json]
indent_style = space
indent_size = 2

[*.yml]
indent_style = space
indent_size = 2

[*.{js,ts}]
quote_type = single

# 1. Surrender indentation math to Prettier for JS, CSS, and Markdown
[*.{js,css,md}]
indent_size = unset
indent_style = unset

# 2. Disable strict line lengths for JS, Markdown, text, and JSON
[*.{js,md,txt,json}]
max_line_length = unset

# 3. Allow trailing spaces inside JS template literals (backticks)
[*.js]
trim_trailing_whitespace = unset

# 4. Standard Markdown double-space line breaks
[*.md]
trim_trailing_whitespace = false

# 5. Ignore formatting rules for hidden/config/system files
[.{env,dockerignore,gitignore,npmignore,nvmrc}*]
insert_final_newline = unset
trim_trailing_whitespace = unset
end_of_line = unset
